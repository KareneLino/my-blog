# Server env (example)
# Copy to `server/.env` for local development.
# 
# IMPORTANT:
# - Do NOT commit `server/.env` (it contains real secrets).
# - This configuration REQUIRES MongoDB authentication by default (security first!).
# - Rotate any secrets that were previously exposed.

# Server port
PORT=3000

# ==========================================
# MongoDB Configuration (Authentication Required)
# ==========================================
# WARNING: MongoDB authentication is REQUIRED by default.
# If you see "Authentication failed" errors, either:
#   1. Set correct MONGO_USERNAME/MONGO_PASSWORD below, OR
#   2. Explicitly disable auth by setting MONGO_AUTH_ENABLED=false (not recommended)

MONGO_DBNAME=myblog
MONGO_HOST=127.0.0.1
MONGO_PORT=27017

# MongoDB user credentials (REQUIRED - security first!)
# If your MongoDB has no auth enabled, you must explicitly set MONGO_AUTH_ENABLED=false
MONGO_USERNAME=your_db_user
MONGO_PASSWORD=your_db_password

# Auth source database (default: same as MONGO_DBNAME)
# Common values: 'admin' (if user created in admin db) or 'myblog' (if user created in app db)
MONGO_AUTH_SOURCE=myblog

# ==========================================
# Security: Explicitly disable auth (NOT recommended)
# ==========================================
# Only set to 'false' if you are ABSOLUTELY sure your MongoDB has no auth enabled
# and you are in a completely isolated/trusted environment.
# MONGO_AUTH_ENABLED=false

# JWT Secret (used for login tokens)
# For local dev, you can use any string. For production, use a strong random secret!
JWT_SECRET=dev_secret_change_in_production

# ==========================================
# Optional: Default Admin Account
# ==========================================
# Used by createAdmin.ts script to create the first admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=StrongAdminPass123!

# ==========================================
# Alternative: Full MongoDB Connection URI
# ==========================================
# If you prefer, you can provide a complete connection string instead:
# MONGO_URI=mongodb://user:pass@host:port/db?authSource=admin
# When MONGO_URI is set, it overrides the individual settings above.

# ==========================================
# Optional Features (can leave as default)
# ==========================================

# Upload settings
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
PUBLIC_BASE_URL=http://localhost:3000

# System config (dev features)
SYSTEM_CONFIG_DEV_PREVIEW=true
SYSTEM_CONFIG_DEV_PREVIEW_PATH=.tmp/system-config.preview.json
SYSTEM_CONFIG_CACHE=false
SYSTEM_CONFIG_APPLY_ON_PUBLISH=true

# Frontend sync (for export features)
FRONTEND_SITE_CONFIG_PATH=../frontend/src/site.config.ts
FRONTEND_CONTENT_SYNC=false
FRONTEND_CONTENT_OUT_DIR=../frontend/src/content/posts/_generated

# Logging
LOG_DIR=logs

# Extra account (for scripts)
USER_USERNAME=author
USER_PASSWORD=author123
